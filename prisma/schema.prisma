generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Enrollment {
  id          String   @id @default(cuid())
  classId     String
  studentId   String
  studentName String
  enrolledAt  DateTime @default(now())

  @@unique([classId, studentId])
}