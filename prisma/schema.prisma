generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Enrollment {
  id         String   @id @default(cuid())
  classId    String
  studentId  String
  enrolledAt DateTime @default(now())
  Class      Class    @relation(fields: [classId], references: [id])
  User       User     @relation(fields: [studentId], references: [id])

  @@unique([classId, studentId])
}

model Account {
  id                String  @id
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  User              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Assignment {
  id          String       @id
  postId      String       @unique
  classId     String
  title       String
  description String
  dueDate     DateTime
  maxScore    Int          @default(100)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime
  Class       Class        @relation(fields: [classId], references: [id])
  Submission  Submission[]
}

model Class {
  id          String       @id
  name        String
  section     String?
  subject     String
  room        String?
  teacherId   String
  teacherName String
  coverColor  String
  inviteCode  String       @unique
  createdAt   DateTime     @default(now())
  updatedAt   DateTime
  Assignment  Assignment[]
  User        User         @relation(fields: [teacherId], references: [id])
  Enrollment  Enrollment[]
  Post        Post[]
}

model Comment {
  id         String   @id
  postId     String
  authorId   String
  authorName String
  content    String
  createdAt  DateTime @default(now())
  User       User     @relation(fields: [authorId], references: [id])
  Post       Post     @relation(fields: [postId], references: [id])
}

model Notification {
  id        String   @id
  userId    String
  type      String
  title     String
  message   String
  link      String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
  User      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Post {
  id           String    @id
  classId      String
  authorId     String
  authorName   String
  authorRole   String
  title        String
  content      String
  type         String
  assignmentId String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime
  Comment      Comment[]
  User         User      @relation(fields: [authorId], references: [id])
  Class        Class     @relation(fields: [classId], references: [id])
}

model Session {
  id           String   @id
  sessionToken String   @unique
  userId       String
  expires      DateTime
  User         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Submission {
  id           String     @id
  assignmentId String
  studentId    String
  studentName  String
  content      String
  score        Int?
  feedback     String?
  submittedAt  DateTime   @default(now())
  gradedAt     DateTime?
  attachments  String[]
  Assignment   Assignment @relation(fields: [assignmentId], references: [id])
  User         User       @relation(fields: [studentId], references: [id])
}

model User {
  id            String         @id
  email         String         @unique
  name          String?
  role          String         @default("student")
  createdAt     DateTime       @default(now())
  updatedAt     DateTime
  emailVerified DateTime?
  image         String?
  Account       Account[]
  Class         Class[]
  Comment       Comment[]
  Enrollment    Enrollment[]
  Notification  Notification[]
  Post          Post[]
  Session       Session[]
  Submission    Submission[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
